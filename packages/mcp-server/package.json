{
  "name": "@mcp-server/mcp-server",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "NODE_ENV=development tsx watch src/server.ts",
    "dev:watch": "NODE_ENV=development tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test:unit": "vitest run --mode=test unit",
    "test:integration": "vitest run --mode=test integration",
    "test:e2e": "playwright test",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/cors": "^8.4.0",
    "@mcp-server/arcgis-client": "workspace:*",
    "@mcp-server/rag-engine": "workspace:*",
    "@mcp-server/shared-types": "workspace:*",
    "dotenv-safe": "^9.0.0",
    "fastify": "^4.25.0",
    "fastify-metrics": "^5.0.0",
    "pino": "^9.0.0",
    "pm2": "^5.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/dotenv-safe": "^9.1.0",
    "@types/node": "^20.10.0",
    "supertest": "^7.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
