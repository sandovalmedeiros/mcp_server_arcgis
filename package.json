{
  "name": "mcp-server-mapoteca",
  "version": "1.0.0",
  "description": "MCP Server para Mapoteca Digital com Hybrid RAG",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter mcp-server dev",
    "dev:mcp": "pnpm --filter mcp-server dev",
    "dev:watch": "pnpm --filter mcp-server dev:watch",
    "build": "pnpm -r build",
    "build:prod": "pnpm -r build --mode=production",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r run test:unit",
    "test:integration": "pnpm -r run test:integration",
    "test:e2e": "pnpm -r run test:e2e",
    "test:coverage": "pnpm -r run test:coverage",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "clean": "pnpm -r exec rm -rf dist node_modules",
    "docker:build": "docker build -t mcp-server:latest -f docker/Dockerfile.mcp-server .",
    "docker:up": "docker-compose -f docker/docker-compose.yml up -d",
    "docker:logs": "docker-compose -f docker/docker-compose.yml logs -f",
    "docker:down": "docker-compose -f docker/docker-compose.yml down"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "keywords": [
    "mcp",
    "rag",
    "arcgis",
    "mapoteca",
    "hybrid-search"
  ],
  "author": "SEIGEO/DIGEO",
  "license": "MIT"
}
