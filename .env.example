# === API Authentication ===
MCP_API_KEYS=mcp-key-dev-123,mcp-key-prod-456

# === ArcGIS Configuration ===
ARCGIS_FEATURESERVER_URL=https://map.geo.sei.ba.gov.br/arcgis/rest/services/servicos_mapoteca_hml/mapoteca_publicacao_consulta_hml/FeatureServer
ARCGIS_MAPSERVER_URL=https://map.geo.sei.ba.gov.br/arcgis/rest/services/servicos_mapoteca_hml/mapoteca_views_publico/MapServer
ARCGIS_TIMEOUT_MS=30000

# === RAG Configuration ===
RAG_STRATEGY_DEFAULT=hybrid
RAG_MAX_RESULTS=100
RAG_EMBEDDING_MODEL=xlm-roberta-base
RAG_VECTOR_STORE_TYPE=memory

# === Server Configuration ===
SERVER_PORT=3000
SERVER_HOST=0.0.0.0
LOG_LEVEL=info

# === Rate Limiting ===
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# === Development ===
NODE_ENV=development
ENABLE_CORS=true
CORS_ORIGINS=http://localhost:3000,http://evo-ai:3000
